  notes          String?  @db.Text
  hoursWorked    Float?
  createdBy      String   @db.VarChar(255)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, date])
  @@index([organizationId, assignee])
  @@index([propertyId])
}

// ==========================================
// Tax Reports
// ==========================================

model TaxReport {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String   @db.VarChar(255)
  period         String   @db.VarChar(50) // monthly, quarterly, annual
  year           Int
  quarter        Int?     // 1-4 for quarterly
  month          Int?     // 1-12 for monthly
  totalIncome    Float    @default(0)
  totalExpenses  Float    @default(0)
  netIncome      Float    @default(0)
  taxableAmount  Float    @default(0)
  taxRate        Float?   // percentage
  estimatedTax   Float    @default(0)
  deductions     Json?    // { category: string, amount: number }[]
  propertyBreakdown Json? // { propertyId: string, propertyName: string, income: number, expenses: number }[]
  status         String   @default("draft") @db.VarChar(50) // draft, finalized, filed
  notes          String?  @db.Text
  filedAt        DateTime?
  createdBy      String   @db.VarChar(255)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, year])
  @@index([organizationId, status])
}

